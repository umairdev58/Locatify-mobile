# Copy to .env for local dev. EAS builds read EXPO_PUBLIC_* from eas.json (see build profiles) or Expo dashboard env vars.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Optional. Example: http://192.168.1.10:8000/api for a physical device on your LAN. Omit to use emulator defaults in dev.
# EXPO_PUBLIC_API_BASE_URL=
