{
  "expo": {
    "name": "Locatify",
    "slug": "locatify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "description": "Save and share precise locations with delivery codes, maps, and reference photos.",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#c5d8e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.locatify.app",
      "infoPlist": {
        "CFBundleDisplayName": "Locatify",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["comgooglemaps", "maps", "googlechromes"]
      }
    },
    "android": {
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "versionCode": 1,
      "label": "Locatify",
      "package": "com.locatify.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f8fafc"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAdiFile",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#c5d8e8",
          "imageWidth": 260
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c62ec831-4718-492b-bac7-38c89837592c"
      }
    },
    "owner": "mianumair22"
  }
}
